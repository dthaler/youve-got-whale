{
    "IsEncrypted": false,
    "Values": {
        "AzureWebJobsStorage": "UseDevelopmentStorage=true",
        "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
        "CosmosDbConnection": "<read-only-detections-cosmos-db-connection-string>",
        "CosmosDbDatabase": "predictions",
        "CosmosDbContainer": "metadata",
        "NotificationCosmosDbConnection": "<read-write-notifications-cosmos-db-connection-string>",
        "NotificationCosmosDbDatabase": "orcasound-cosmosdb",
        "NotificationCosmosDbContainer": "Notifications",
        "AppNotificationUrl": "<your-ifttt-webhook-url>",
        "LocationId": "<hydrophone-location-id>",
        "NotificationPeriodMinutes": "60",
        "DetectionPeriodMinutes": "15"
    }
}
